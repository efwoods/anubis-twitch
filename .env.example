# Twitch app client id from https://dev.twitch.tv/console/apps
# (implicit OAuth — no client secret required)
CLIENT_ID=

# Bot account numeric user id
BOT_USER_ID=

# Channel numeric user id to listen/speak in
CHAT_CHANNEL_USER_ID=

# Paste the access token from the oauth callback page
OAUTH_TOKEN=

# Optional overrides
# OAUTH_REDIRECT_URI=http://localhost:9070
# OAUTH_PORT=9070
